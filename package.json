{
  "name": "desktop-pet",
  "version": "0.1.0",
  "description": "A cross-platform desktop pet that reacts when your AI assistant is working.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "notify": "node hooks/pet-notify.js",
    "test": "node pettest.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.desktoppet.app",
    "productName": "Desktop Pet",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.entertainment",
      "extendInfo": {
        "LSUIElement": 1
      }
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility"
    }
  }
}
